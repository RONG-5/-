<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>物品识别网页</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft Yahei", sans-serif;
        }
        body {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
        }
        .header {
            text-align: center;
            color: white;
            margin-bottom: 30px;
        }
        .container {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            width: 100%;
            max-width: 600px;
        }
        .input-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            color: #333;
            font-weight: bold;
        }
        input {
            width: 100%;
            padding: 12px;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
            transition: border-color 0.3s;
        }
        input:focus {
            border-color: #f5576c;
            outline: none;
        }
        button {
            width: 100%;
            padding: 14px;
            background: #f5576c;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 18px;
            cursor: pointer;
            transition: background 0.3s;
        }
        button:hover {
            background: #d94358;
        }
        #result {
            margin-top: 25px;
            text-align: center;
        }
        #result img {
            max-width: 100%;
            max-height: 300px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        #result p {
            margin-top: 10px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="header">
        <h2>班级：科大讯飞（5）班</h2>
        <h3>学号：2409060531</h3>
        <h3>姓名：全泳涛</h3>
    </div>
    <div class="container">
        <div class="input-group">
            <label for="itemInput">输入水果/动物/物品名称（中文或英文）：</label>
            <input type="text" id="itemInput" placeholder="例如：苹果 / Apple / 猫 / Cat">
        </div>
        <button onclick="searchImage()">显示图片</button>
        <div id="result"></div>
    </div>

    <script>
        // 完善图片链接的示例图片映射库，支持更多常用物品
        const imageMap = {
            "苹果": "https://images.unsplash.com/photo-1560806887-1e4cdb906c96?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80",
            "apple": "https://images.unsplash.com/photo-1560806887-1e4cdb906c96?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80",
            "香蕉": "https://images.unsplash.com/photo-1528825871115-3581a5387919?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80",
            "banana": "https://images.unsplash.com/photo-1528825871115-3581a5387919?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80",
            "猫": "https://images.unsplash.com/photo-1574158622682-e40e69881006?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80",
            "cat": "https://images.unsplash.com/photo-1574158622682-e40e69881006?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80",
            "狗": "https://images.unsplash.com/photo-1587300003388-59208cc962cb?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80",
            "dog": "https://images.unsplash.com/photo-1587300003388-59208cc962cb?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80",
            "书": "https://images.unsplash.com/photo-1544716278-ca5e3f4abd8c?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80",
            "book": "https://images.unsplash.com/photo-1544716278-ca5e3f4abd8c?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80",
            "篮球": "https://images.unsplash.com/photo-1518623489648-a173ef7824f3?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80",
            "basketball": "https://images.unsplash.com/photo-1518623489648-a173ef7824f3?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80"
        };

        function searchImage() {
            const input = document.getElementById("itemInput").value.trim().toLowerCase();
            const resultDiv = document.getElementById("result");

            if (imageMap[input]) {
                resultDiv.innerHTML = `
                    <img src="${imageMap[input]}" alt="${input}">
                    <p>识别结果：${input}</p>
                `;
            } else {
                resultDiv.innerHTML = `<p style="color: red;">未找到该物品图片，请尝试输入：苹果、香蕉、猫、狗、书、篮球</p>`;
            }
        }
    </script>
</body>
</html>